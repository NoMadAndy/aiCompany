# ═══════════════════════════════════════════════
# AI Company — Konfiguration (Vorlage)
# Kopiere diese Datei nach .env und passe an.
# ═══════════════════════════════════════════════

# ─── Ports ────────────────────────────────────
FRONTEND_PORT=3002
WORKER_PORT=8080

# ─── Datenbank ────────────────────────────────
POSTGRES_DB=aicompany
POSTGRES_USER=aicompany
POSTGRES_PASSWORD=aicompany
DATABASE_URL=postgresql://aicompany:aicompany@db:5432/aicompany

# ─── Redis ────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── AI / Modelle ─────────────────────────────
ANTHROPIC_API_KEY=
LOCAL_MODEL=Qwen/Qwen2.5-3B-Instruct

# ─── App URLs ─────────────────────────────────
NEXT_PUBLIC_WS_URL=wss://aicompany.macherwerkstatt.cc
NEXT_PUBLIC_APP_URL=https://aicompany.macherwerkstatt.cc
WORKER_URL=http://worker:8080

# ─── Auth / Sicherheit ───────────────────────
SESSION_SECRET=CHANGE-ME-random-64-chars
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin
